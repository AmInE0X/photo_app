@prefix : <http://example.org/library#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/library> rdf:type owl:Ontology .

### Classes ###
:Book rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :title ;
                        owl:cardinality "1"^^xsd:nonNegativeInteger ] .

:PublishedBook rdf:type owl:Class ;
               rdfs:subClassOf :Book .

:Author rdf:type owl:Class .
:Category rdf:type owl:Class .
:Publisher rdf:type owl:Class .

### Object Properties ###
:writtenBy rdf:type owl:ObjectProperty ;
           rdfs:domain :Book ;
           rdfs:range :Author .

:isAuthorOf rdf:type owl:ObjectProperty ;
            owl:inverseOf :writtenBy ;
            rdfs:domain :Author ;
            rdfs:range :Book .

:belongsTo rdf:type owl:ObjectProperty ;
           rdfs:domain :Book ;
           rdfs:range :Category .

:publishedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :PublishedBook ;
             rdfs:range :Publisher .

### Data Properties ###
:title rdf:type owl:DatatypeProperty ;
       rdfs:domain :Book ;
       rdfs:range xsd:string .

:addedBy rdf:type owl:DatatypeProperty ;
         rdfs:domain :Book ;
         rdfs:range xsd:string .

:name rdf:type owl:DatatypeProperty ;
      rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( :Author :Category :Publisher ) ] ;
      rdfs:range xsd:string .
